    {
      "name": "Forgot Password",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "let res;\r",
              "try {\r",
              "    res = pm.response.json();\r",
              "} catch (e) {\r",
              "    res = {};\r",
              "}\r",
              "\r",
              "\r",
              "pm.test(\"Status code is 200  0r 201\", function () {\r",
              "    pm.expect([200,201]).to.include(pm.response.code);\r",
              "});\r",
              "\r",
              "\r",
              "if (pm.response.code === 200) {\r",
              "\r",
              "    const successSchema = {\r",
              "        type: \"object\",\r",
              "        required: [\"token\", \"type\", \"userId\", \"email\", \"roles\", \"status\", \"passwordExpired\"],\r",
              "        properties: {\r",
              "            token: { type: \"string\" },\r",
              "            type: { type: \"string\" },\r",
              "            userId: { type: \"string\" },\r",
              "            email: { type: \"string\" },\r",
              "            roles: {\r",
              "                type: \"array\",\r",
              "                items: { type: \"string\" }\r",
              "            },\r",
              "            status: { type: \"string\" },\r",
              "            passwordExpired: { type: \"boolean\" }\r",
              "        }\r",
              "    };\r",
              "    pm.test(\"Response schema is valid for 200\", function () {\r",
              "        pm.response.to.have.jsonSchema(successSchema);\r",
              "    });\r",
              "    pm.test(\"Response schema is valid for 201\", function () {\r",
              "        pm.response.to.have.jsonSchema(successSchema);\r",
              "    });\r",
              "\r",
              "    pm.test(\"Token is present\", function () {\r",
              "        pm.expect(res.token).to.be.a(\"string\");\r",
              "        pm.expect(res.token).to.not.be.empty;\r",
              "    });\r",
              "\r",
              "    pm.test(\"Type is present\", function () {\r",
              "        pm.expect(res.type).to.be.a(\"string\");\r",
              "    });\r",
              "\r",
              "    pm.test(\"User ID is present\", function () {\r",
              "        pm.expect(res.userId).to.be.a(\"string\");\r",
              "    });\r",
              "\r",
              "    pm.test(\"Email is present\", function () {\r",
              "        pm.expect(res.email).to.be.a(\"string\");\r",
              "    });\r",
              "\r",
              "    pm.test(\"Roles is an array\", function () {\r",
              "        pm.expect(res.roles).to.be.an(\"array\");\r",
              "    });\r",
              "\r",
              "    pm.test(\"Status is present\", function () {\r",
              "        pm.expect(res.status).to.be.a(\"string\");\r",
              "    });\r",
              "\r",
              "    pm.test(\"PasswordExpired is boolean\", function () {\r",
              "        pm.expect(res.passwordExpired).to.be.a(\"boolean\");\r",
              "    });\r",
              "}\r",
              "\r",
              "\r",
              "if (pm.response.code === 400) {\r",
              "\r",
              "    pm.test(\"Bad Request response body is not empty\", function () {\r",
              "        pm.expect(pm.response.text()).to.not.be.empty;\r",
              "    });\r",
              "\r",
              "    pm.test(\"Response contains invalid request body message\", function () {\r",
              "        pm.expect(pm.response.text().toLowerCase()).to.include(\"invalid\");\r",
              "    });\r",
              "}\r",
              "\r",
              "\r",
              "pm.test(\"Response time is > 2m\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(1500);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
